// Prisma Schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================
//    ENUMS
// ============================

enum Role {
  USER
  ADMIN
  STAFF
}

enum AuthProvider {
  EMAIL
  GOOGLE
  FACEBOOK
}

// ===========================
//     MODELS
// ===========================

/////////////////////////
// === USER MODEL ===

model User {
  id String @id @default(cuid(2))

  firstName String
  lastName  String

  email        String  @unique
  passwordHash String?

  avatar     String?
  providerId String?

  role     Role         @default(USER)
  provider AuthProvider @default(EMAIL)

  isEmailVerified Boolean   @default(false)
  emailVerifiedAt DateTime?
  isActive        Boolean   @default(true)
  isDeleted       Boolean   @default(false)

  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  @@index([email])
  @@index([role])
}

//////////////////////////
// === SESSION MODEL ===

model Session {
  id     String @id @default(cuid(2))
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent String?
  ipAddress String?

  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([revokedAt])
  @@index([expiresAt])
}

///////////////////////////////
// === REFRESH TOKEN MODEL ===

model RefreshToken {
  id String @id @default(cuid(2))

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  tokenHash String @unique

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([revokedAt])
}

/////////////////////////////////////////
// === EMAIL VERIFICATION TOKEN MODEL === 

model EmailVerificationToken {
  id String @id @default(cuid(2))

  userId    String
  tokenHash String @unique

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

////////////////////////////////
// === PASSWORD TOKEN MODLE ===

model PasswordResetToken {
  id String @id @default(cuid(2))

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String @unique

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

///////////////////////////
// === CATEGORY MODLE ===

model Category {
  id String @id @default(cuid(2))

  name        String
  slug        String  @unique
  description String?

  imageUrl String?

  isActive Boolean @default(true)

  sortOrder Int @default(0)

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")

  products        Product[]
  metaTitle       String?
  metaDescription String?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
  @@index([deletedAt])
}

/////////////////////////
// === PRODUCT MODEL ===

model Product {
  id String @id @default(cuid(2))

  name        String
  slug        String
  description String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  isPublished Boolean @default(false)

  metaTitle       String?
  metaDescription String?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isPublished])
  @@index([deletedAt])
}

////////////////////////
// ===  BRAND MODEL ===

model Brand {
  id String @id @default(cuid(2))

  name        String  @unique
  slug        String  @unique
  description String?

  logoUrl String?

  isActive Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
